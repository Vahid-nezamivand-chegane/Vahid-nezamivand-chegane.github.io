<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>AquaNexus — انقلاب صنعتی ۱۰۰۰ گیگاوات</title>
    <meta name="description" content="انقلاب صنعتی ۱۰۰۰ گیگاوات · ۴۵٪ سود · ۵۰ سال عمر مفید · ۵ دفتر بین‌المللی · ۶ بازوی درآمدی"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"/>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #0a2a44;
            --secondary: #1a6fb5;
            --accent: #2a9d8f;
            --gold: #e9c46a;
            --light: #f0f7ff;
            --dark: #0b1a2a;
            --shadow: 0 20px 40px rgba(0,0,0,0.08);
            --radius: 20px;
            --transition: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Segoe UI', 'Poppins', system-ui, sans-serif;
            background: var(--light);
            color: var(--dark);
            line-height: 1.8;
            overflow-x: hidden;
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        .section { padding: 80px 0; }
        .section-title {
            font-size: clamp(2rem, 5vw, 2.8rem);
            font-weight: 700;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }
        .section-title .highlight { color: var(--secondary); }
        .section-sub {
            font-size: 1.1rem;
            color: #4a5a6a;
            max-width: 680px;
            margin-bottom: 40px;
            opacity: 0.85;
        }
        .text-center { text-align: center; }
        .text-center .section-sub { margin-left: auto; margin-right: auto; }
        .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; }
        .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; }
        .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
        .grid-5 { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
        .card {
            background: white;
            padding: 32px 26px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            transition: var(--transition);
            border-bottom: 4px solid var(--secondary);
        }
        .card:hover { transform: translateY(-8px); box-shadow: 0 30px 60px rgba(0,0,0,0.10); }
        .card i { font-size: 2.8rem; color: var(--secondary); margin-bottom: 18px; display: inline-block; }
        .card h3 { font-size: 1.4rem; margin-bottom: 10px; }
        .card p { color: #3a4a5a; font-size: 0.98rem; }
        .card img { width: 100%; border-radius: 12px; margin-bottom: 16px; object-fit: cover; height: 200px; }
        .badge {
            display: inline-block;
            background: var(--gold);
            color: var(--dark);
            padding: 4px 14px;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 12px;
        }
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: linear-gradient(135deg, #0a2a44 0%, #1a6fb5 100%);
            color: white;
            padding: 40px 20px;
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: url('https://images.unsplash.com/photo-1535889017049-7f1af2d72cda?w=1400') center/cover no-repeat;
            opacity: 0.25;
            z-index: 0;
        }
        .hero-content {
            position: relative;
            z-index: 1;
            max-width: 900px;
        }
        .hero h1 {
            font-size: clamp(2.5rem, 8vw, 4.5rem);
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 10px;
            text-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }
        .hero .sub-title {
            font-size: 1.6rem;
            font-weight: 300;
            margin-bottom: 16px;
            color: var(--gold);
        }
        .hero p {
            font-size: 1.3rem;
            opacity: 0.9;
            max-width: 700px;
            margin: 0 auto 20px;
        }
        .hero-stats {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px 40px;
            margin-top: 30px;
        }
        .hero-stats span {
            font-size: 1rem;
            background: rgba(255,255,255,0.12);
            padding: 8px 20px;
            border-radius: 40px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .hero .hero-value {
            font-size: 1.2rem;
            background: rgba(233,196,106,0.15);
            padding: 12px 30px;
            border-radius: 40px;
            display: inline-block;
            margin-top: 20px;
            border: 1px solid rgba(233,196,106,0.3);
            color: var(--gold);
        }
        .btn {
            display: inline-block;
            background: var(--gold);
            color: var(--dark);
            padding: 14px 40px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 1.05rem;
            text-decoration: none;
            transition: var(--transition);
            border: none;
            cursor: pointer;
        }
        .btn:hover { transform: scale(1.04); box-shadow: 0 10px 30px rgba(233,196,106,0.3); }
        .btn-secondary {
            background: transparent;
            color: white;
            border: 2px solid rgba(255,255,255,0.4);
        }
        .btn-secondary:hover { background: rgba(255,255,255,0.1); border-color: white; }
        .flag { font-size: 2rem; margin-bottom: 6px; display: block; }
        .office-card { text-align: center; padding: 24px; }
        .office-card h4 { font-size: 1.2rem; margin: 10px 0 4px; }
        .office-card p { color: #5a6a7a; font-size: 0.9rem; }
        .office-card .contact-link {
            display: inline-block;
            margin: 4px 0;
            color: var(--secondary);
            text-decoration: none;
            font-size: 0.95rem;
            transition: var(--transition);
            cursor: pointer;
            background: none;
            border: none;
            font-family: inherit;
        }
        .office-card .contact-link:hover {
            color: var(--gold);
            text-decoration: underline;
        }
        .office-card .contact-link i { font-size: 1rem; margin-left: 6px; color: var(--secondary); }
        .contact-form {
            background: white;
            padding: 40px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            max-width: 750px;
            margin: 0 auto;
        }
        .contact-form .form-row { margin-bottom: 18px; }
        .contact-form input,
        .contact-form select,
        .contact-form textarea {
            width: 100%;
            padding: 14px 18px;
            border: 1px solid #dde4ec;
            border-radius: 12px;
            font-size: 1rem;
            transition: var(--transition);
            font-family: inherit;
            background: #fafcff;
        }
        .contact-form input:focus,
        .contact-form select:focus,
        .contact-form textarea:focus {
            outline: none;
            border-color: var(--secondary);
            box-shadow: 0 0 0 4px rgba(26,111,181,0.1);
        }
        .contact-form textarea { min-height: 120px; resize: vertical; }
        .contact-form .btn { width: 100%; }
        .contact-form .btn-group {
            display: flex;
            gap: 12px;
            margin-top: 10px;
        }
        .contact-form .btn-group .btn { flex: 1; }
        .contact-form .btn-secondary-form {
            background: transparent;
            color: var(--secondary);
            border: 2px solid var(--secondary);
        }
        .contact-form .btn-secondary-form:hover {
            background: var(--secondary);
            color: white;
        }
        .request-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 20px;
            justify-content: center;
        }
        .request-tags .tag {
            padding: 8px 18px;
            border-radius: 30px;
            border: 2px solid #dde4ec;
            background: transparent;
            cursor: pointer;
            transition: var(--transition);
            font-size: 0.9rem;
            font-family: inherit;
            color: #4a5a6a;
        }
        .request-tags .tag:hover,
        .request-tags .tag.active {
            border-color: var(--secondary);
            background: var(--secondary);
            color: white;
        }
        .form-footer {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #eef2f7;
            font-size: 0.9rem;
            color: #6a7a8a;
        }
        .form-footer .direct-email {
            display: none;
            background: linear-gradient(135deg, #0a2a44, #1a6fb5);
            color: white;
            padding: 24px 30px;
            border-radius: var(--radius);
            margin-top: 16px;
            text-align: center;
        }
        .form-footer .direct-email.show { display: block; }
        .form-footer .direct-email .email-box {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--gold);
            background: rgba(255,255,255,0.08);
            padding: 12px 24px;
            border-radius: 12px;
            display: inline-block;
            margin: 10px 0;
            letter-spacing: 1px;
            direction: ltr;
        }
        .form-footer .direct-email .email-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .form-footer .direct-email .email-actions .btn-sm {
            padding: 8px 20px;
            border-radius: 30px;
            border: none;
            font-size: 0.9rem;
            cursor: pointer;
            transition: var(--transition);
            background: rgba(255,255,255,0.15);
            color: white;
        }
        .form-footer .direct-email .email-actions .btn-sm:hover {
            background: var(--gold);
            color: var(--dark);
        }
        .form-footer .warnings {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-top: 12px;
            font-size: 0.88rem;
            color: #8a9aaa;
        }
        .form-footer .warnings i { margin-left: 6px; width: 18px; }
        .status-msg {
            padding: 14px 20px;
            border-radius: 12px;
            margin-top: 16px;
            display: none;
            font-weight: 500;
        }
        .status-msg.success { display: block; background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .status-msg.error { display: block; background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .footer {
            background: var(--dark);
            color: rgba(255,255,255,0.7);
            padding: 40px 20px;
            text-align: center;
            margin-top: 40px;
        }
        .footer a { color: var(--gold); text-decoration: none; }
        .dropdown-wrapper {
            position: relative;
            margin-top: 10px;
        }
        .dropdown-wrapper select {
            width: 100%;
            padding: 14px 18px;
            border: 1px solid #dde4ec;
            border-radius: 12px;
            font-size: 1rem;
            font-family: inherit;
            background: #fafcff;
            appearance: none;
            cursor: pointer;
        }
        .dropdown-wrapper select:focus {
            outline: none;
            border-color: var(--secondary);
            box-shadow: 0 0 0 4px rgba(26,111,181,0.1);
        }
        .dropdown-wrapper::after {
            content: '\f078';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #8a9aaa;
            pointer-events: none;
        }
        @media (max-width: 600px) {
            .section { padding: 50px 0; }
            .hero-stats { gap: 12px; }
            .hero-stats span { font-size: 0.85rem; padding: 6px 14px; }
            .grid-2 { grid-template-columns: 1fr; }
            .grid-3 { grid-template-columns: 1fr; }
            .grid-4 { grid-template-columns: 1fr 1fr; }
            .grid-5 { grid-template-columns: 1fr 1fr; }
            .contact-form { padding: 24px; }
            .contact-form .btn-group { flex-direction: column; }
            .form-footer .direct-email .email-box { font-size: 1.2rem; padding: 10px 16px; }
            .request-tags .tag { font-size: 0.8rem; padding: 6px 14px; }
        }
    </style>
</head>
