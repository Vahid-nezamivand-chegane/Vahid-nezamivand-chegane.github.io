            margin-top: 4px; letter-spacing: 1px;
        }
        .hero .hero-content .hero-title {
            font-size: clamp(0.95rem, 1.5vw, 1.3rem); font-weight: 400;
            color: rgba(255,255,255,0.85); margin-top: 2px; letter-spacing: 0.5px;
        }
        .hero .hero-content .hero-desc {
            font-size: clamp(1rem, 1.6vw, 1.4rem); font-weight: 300;
            color: rgba(255,255,255,0.9); margin-top: 12px; letter-spacing: 2px;
            border-top: 1px solid rgba(255,255,255,0.15); padding-top: 12px;
        }
        .hero .hero-content .hero-tags {
            font-size: clamp(0.8rem, 1.2vw, 1.1rem); font-weight: 300;
            color: rgba(255,255,255,0.7); margin-top: 6px; letter-spacing: 1px;
        }
        .hero .hero-content .hero-footer {
            font-size: clamp(0.8rem, 1.1vw, 1rem); font-weight: 300;
            color: rgba(255,255,255,0.5); margin-top: 10px; letter-spacing: 2px;
            border-top: 1px solid rgba(255,255,255,0.08); padding-top: 10px;
        }

        .menu-toggle {
            position: fixed; top: 20px; left: 20px; z-index: 1000;
            background: rgba(10,42,68,0.75); backdrop-filter: blur(12px); border: none;
            color: white; font-size: 1.8rem; padding: 8px 16px; border-radius: 40px;
            cursor: pointer; transition: var(--transition); border: 1px solid rgba(255,255,255,0.15);
        }
        .menu-toggle:hover { background: rgba(10,42,68,0.9); }
        .menu-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); z-index: 999; display: none;
        }
        .menu-overlay.open { display: block; }
        .mobile-menu {
            position: fixed; top: 0; left: -340px; width: 320px; height: 100%;
            background: var(--dark); z-index: 1001; padding: 30px 20px; overflow-y: auto;
            transition: left 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94); box-shadow: 4px 0 30px rgba(0,0,0,0.4);
        }
        .mobile-menu.open { left: 0; }
        .mobile-menu .menu-header {
            color: white; font-family: 'Poppins', sans-serif; font-size: 1.4rem; font-weight: 700;
            letter-spacing: 1px; padding-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 20px; text-align: center;
            background: linear-gradient(135deg, #fff 30%, var(--gold) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .mobile-menu .close-menu {
            background: transparent; border: none; color: white; font-size: 2rem; float: right; cursor: pointer; opacity: 0.7;
        }
        .mobile-menu .close-menu:hover { opacity: 1; }
        .mobile-menu ul { list-style: none; padding: 0; margin-top: 10px; }
        .mobile-menu ul li { margin-bottom: 4px; }
        .mobile-menu ul li a {
            display: block; color: rgba(255,255,255,0.8); text-decoration: none; font-size: 1rem;
            padding: 10px 16px; border-radius: 10px; transition: var(--transition);
            border-left: 3px solid transparent; font-weight: 400; letter-spacing: 0.3px; font-family: 'Inter', sans-serif;
        }
        .mobile-menu ul li a:hover {
            background: rgba(255,255,255,0.06); color: white; border-left-color: var(--gold);
        }
        .globe-section {
            background: var(--dark); color: white; padding: 60px 0; text-align: center;
            position: relative; overflow: hidden; min-height: 500px;
        }
        .globe-section .globe-container { width: 100%; height: 450px; max-width: 600px; margin: 0 auto; }
        .globe-section h2 { font-family: 'Poppins', sans-serif; font-size: 2.2rem; margin-bottom: 10px; }
        .globe-section p { opacity: 0.8; margin-bottom: 30px; font-size: 1.1rem; }
        .achievement-item {
            display: flex; align-items: center; gap: 20px;
            background: rgba(255,255,255,0.92); backdrop-filter: blur(4px);
            padding: 16px 24px; border-radius: var(--radius); box-shadow: var(--shadow);
            margin-bottom: 16px; transition: var(--transition);
        }
        .achievement-item:hover { transform: translateX(8px); }
        .achievement-item img {
            width: 80px; height: 80px; object-fit: contain; border-radius: 12px;
            flex-shrink: 0; background: white; padding: 4px;
        }
        .achievement-item .ach-text { flex: 1; }
        .achievement-item .ach-text h4 { font-family: 'Poppins', sans-serif; font-size: 1.1rem; margin-bottom: 2px; }
        .achievement-item .ach-text p { color: #6a7a8a; font-size: 0.95rem; margin: 0; }
        .university-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
            gap: 16px; margin-top: 20px;
        }
        .university-grid .uni-item {
            background: rgba(255,255,255,0.92); backdrop-filter: blur(4px);
            padding: 14px 12px; border-radius: 14px; box-shadow: var(--shadow);
            text-align: center; transition: var(--transition); border-bottom: 3px solid var(--secondary);
        }
