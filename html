        .partner-item p { font-size: 0.75rem; color: #6a7a8a; }
        .modal-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); z-index: 2000; justify-content: center; align-items: center;
            backdrop-filter: blur(6px);
        }
        .modal-overlay.open { display: flex; }
        .modal-box {
            background: white; max-width: 560px; width: 95%; border-radius: var(--radius);
            padding: 40px 30px; box-shadow: 0 30px 60px rgba(0,0,0,0.3); max-height: 90vh; overflow-y: auto;
