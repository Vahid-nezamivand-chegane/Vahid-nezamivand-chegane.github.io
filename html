        .modal-box .radio-group label { display: flex; align-items: center; gap: 6px; font-weight: 400; cursor: pointer; }
        .modal-box .calc-result {
            background: var(--light-bg); padding: 16px 20px; border-radius: 12px; margin: 16px 0;
            font-family: 'Poppins', sans-serif; font-size: 1.1rem; text-align: center; border-left: 4px solid var(--secondary);
