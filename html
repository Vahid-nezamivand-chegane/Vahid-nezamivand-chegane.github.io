            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }
        .section-title .highlight { color: var(--secondary); }
        .section-sub {
            font-size: 1.15rem;
            color: #3a4a5a;
            max-width: 680px;
            margin-bottom: 40px;
            opacity: 0.9;
            font-weight: 400;
