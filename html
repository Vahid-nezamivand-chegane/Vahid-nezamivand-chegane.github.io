        .lang-switcher button.active { opacity: 1; background: rgba(255,255,255,0.2); }
        .lang-switcher .flag-icon { font-size: 1.2rem; }

        .hero {
            width: 100%; height: 100vh; overflow: hidden; position: relative;
            display: flex; align-items: center; justify-content: center; background: var(--dark);
        }
