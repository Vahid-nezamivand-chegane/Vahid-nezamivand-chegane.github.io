            position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #8a9aaa; pointer-events: none;
        }
        .lang-switcher {
            position: fixed; top: 20px; right: 20px; z-index: 999;
            display: flex; gap: 6px;
            background: rgba(255,255,255,0.12); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            padding: 8px 14px; border-radius: 50px; border: 1px solid rgba(255,255,255,0.25);
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
