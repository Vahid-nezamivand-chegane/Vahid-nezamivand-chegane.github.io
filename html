<script>
    // ===== LANGUAGE SWITCHER (AR, EN, FR) =====
    function switchLang(lang) {
        document.querySelectorAll('.lang-switcher button').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.lang === lang);
        });
        document.querySelectorAll('[data-lang]').forEach(el => {
            if (el.dataset.lang === lang) {
                el.style.display = '';
            } else {
                el.style.display = 'none';
            }
        });
        document.querySelectorAll('input[data-lang], textarea[data-lang], select[data-lang]').forEach(el => {
            if (el.dataset.lang === lang) {
                el.style.display = '';
            } else {
                el.style.display = 'none';
            }
        });
        document.querySelectorAll('#contactPerson option[data-lang]').forEach(opt => {
            if (opt.dataset.lang === lang) {
                opt.style.display = '';
            } else {
                opt.style.display = 'none';
            }
        });
        document.querySelectorAll('.request-tags .tag').forEach(tag => {
            tag.querySelectorAll('[data-lang]').forEach(el => {
                if (el.dataset.lang === lang) {
                    el.style.display = '';
                } else {
                    el.style.display = 'none';
                }
            });
        });
        document.querySelectorAll('#directEmailBox [data-lang]').forEach(el => {
            if (el.dataset.lang === lang) {
                el.style.display = '';
            } else {
                el.style.display = 'none';
            }
        });
        document.querySelectorAll('.footer [data-lang]').forEach(el => {
            if (el.dataset.lang === lang) {
                el.style.display = '';
            } else {
                el.style.display = 'none';
            }
        });
        document.querySelectorAll('.modal-box [data-lang]').forEach(el => {
            if (el.dataset.lang === lang) {
                el.style.display = '';
            } else {
                el.style.display = 'none';
            }
        });
        document.querySelectorAll('.contact-opt[data-lang]').forEach(el => {
            if (el.dataset.lang === lang) {
                el.style.display = 'inline-block';
            } else {
                el.style.display = 'none';
            }
        });
        document.querySelectorAll('.mobile-menu .menu-header[data-lang]').forEach(el => {
            if (el.dataset.lang === lang) {
                el.style.display = 'block';
            } else {
                el.style.display = 'none';
            }
        });
        document.querySelectorAll('.mobile-menu ul li a[data-lang]').forEach(el => {
            if (el.dataset.lang === lang) {
                el.style.display = 'block';
            } else {
                el.style.display = 'none';
            }
        });
        localStorage.setItem('aquanexus-lang', lang);
        document.documentElement.lang = lang;
        document.documentElement.dir = (lang === 'ar') ? 'rtl' : 'ltr';
    }

    document.addEventListener('DOMContentLoaded', function() {
        const saved = localStorage.getItem('aquanexus-lang') || 'ar';
        switchLang(saved);
    });

    // ===== MOBILE MENU =====
    const menuToggle = document.getElementById('menuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    const menuOverlay = document.getElementById('menuOverlay');
    const closeMenu = document.getElementById('closeMenu');
    function openMenu() { mobileMenu.classList.add('open'); menuOverlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeMenuFn() { mobileMenu.classList.remove('open'); menuOverlay.classList.remove('open'); document.body.style.overflow = ''; }
    menuToggle.addEventListener('click', openMenu);
    closeMenu.addEventListener('click', closeMenuFn);
    menuOverlay.addEventListener('click', closeMenuFn);
    document.querySelectorAll('.mobile-menu ul li a').forEach(link => {
        link.addEventListener('click', closeMenuFn);
    });

    // ===== THREE.JS GLOBE =====
    (function() {
        const container = document.getElementById('globeContainer');
        if (!container) return;
        const width = container.clientWidth, height = container.clientHeight || 450;
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(45, width/height, 0.1, 1000);
        camera.position.z = 3;
        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
        renderer.setSize(width, height);
        renderer.setPixelRatio(window.devicePixelRatio);
        container.appendChild(renderer.domElement);
        const geometry = new THREE.SphereGeometry(1.2, 64, 64);
        const textureLoader = new THREE.TextureLoader();
        const texture = textureLoader.load('https://threejs.org/examples/textures/planets/earth_atmos_2048.jpg');
        const material = new THREE.MeshPhongMaterial({ map: texture, specular: new THREE.Color('gold'), shininess: 10 });
        const globe = new THREE.Mesh(geometry, material);
        scene.add(globe);
        const ringGeo = new THREE.TorusGeometry(1.5, 0.015, 32, 100);
        const ringMat = new THREE.MeshBasicMaterial({ color: 0xe9c46a, transparent: true, opacity: 0.3 });
        const ring = new THREE.Mesh(ringGeo, ringMat);
        ring.rotation.x = Math.PI / 2;
        scene.add(ring);
        const light1 = new THREE.PointLight(0xffffff, 1); light1.position.set(5,3,5); scene.add(light1);
        const light2 = new THREE.PointLight(0x1a6fb5, 0.5); light2.position.set(-3,-1,-4); scene.add(light2);
        const ambient = new THREE.AmbientLight(0x404060, 0.4); scene.add(ambient);
        const starsGeometry = new THREE.BufferGeometry();
        const starsCount = 3000;
        const starPositions = new Float32Array(starsCount*3);
        for (let i=0; i<starsCount*3; i++) starPositions[i] = (Math.random()-0.5)*200;
        starsGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
        const starsMaterial = new THREE.PointsMaterial({ color: 0xffffff, size: 0.15, transparent: true });
        const stars = new THREE.Points(starsGeometry, starsMaterial);
        scene.add(stars);
        let mouseX=0, mouseY=0;
        document.addEventListener('mousemove', function(e) {
            const rect = container.getBoundingClientRect();
            const x = (e.clientX - rect.left)/rect.width - 0.5;
            const y = (e.clientY - rect.top)/rect.height - 0.5;
            mouseX = x*0.5; mouseY = y*0.3;
        });
        function animate() {
            requestAnimationFrame(animate);
            globe.rotation.y += 0.003;
            globe.rotation.x += mouseY*0.002;
            globe.rotation.y += mouseX*0.002;
            ring.rotation.z += 0.001;
            stars.rotation.y += 0.0002;
            renderer.render(scene, camera);
        }
        animate();
        window.addEventListener('resize', function() {
            const w = container.clientWidth, h = container.clientHeight || 450;
            camera.aspect = w/h; camera.updateProjectionMatrix(); renderer.setSize(w,h);
        });
    })();

    // ===== FORM FUNCTIONS =====
    function selectTag(el) {
        document.querySelectorAll('.request-tags .tag').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        document.getElementById('requestType').value = el.dataset.value;
    }

    function setContactType(type) {
        document.querySelectorAll('.contact-opt').forEach(opt => opt.classList.remove('active'));
        document.querySelector(`.contact-opt[data-contact="${type}"]`).classList.add('active');
    }

    function showDirectEmail() {
        document.getElementById('directEmailBox').style.display = 'block';
        document.getElementById('directEmailBox').scrollIntoView({ behavior: 'smooth', block: 'center' });
        document.getElementById('statusMsg').className = 'status-msg';
        document.getElementById('statusMsg').textContent = '';
    }

    function hideDirectEmail() {
        document.getElementById('directEmailBox').style.display = 'none';
    }

    function copyEmail() {
        const email = 'vahid.aquanexus@protonmail.com';
        navigator.clipboard.writeText(email).then(() => {
            showStatus('Email copied successfully!', 'success');
        }).catch(() => {
            const input = document.createElement('input');
            input.value = email;
            document.body.appendChild(input);
            input.select();
            document.execCommand('copy');
            document.body.removeChild(input);
            showStatus('Email copied successfully!', 'success');
        });
    }

    function showStatus(msg, type) {
        const el = document.getElementById('statusMsg');
        el.className = 'status-msg ' + type;
        el.textContent = msg;
        setTimeout(() => { el.className = 'status-msg'; el.textContent = ''; }, 4000);
    }

    function handleSubmit(e) {
        e.preventDefault();
        const email = document.getElementById('email').value.trim();
        const company = document.getElementById('company').value.trim();
        const message = document.getElementById('message').value.trim();
        const msgBox = document.getElementById('statusMsg');

        const lang = document.documentElement.lang || 'en';
        const msgs = {
            en: { error: 'Please fill in all required fields (Company, Email, Message).', invalid: 'Please enter a valid email address.', success: 'Your message was sent successfully. Our team will contact you shortly.' },
            ar: { error: 'يرجى ملء جميع الحقول المطلوبة (اسم الشركة، البريد الإلكتروني، الرسالة).', invalid: 'يرجى إدخال بريد إلكتروني صالح.', success: 'تم إرسال رسالتك بنجاح. سيتواصل معك فريقنا قريباً.' },
            fr: { error: 'Veuillez remplir tous les champs obligatoires (Nom de l\'entreprise, E-mail, Message).', invalid: 'Veuillez entrer une adresse e-mail valide.', success: 'Votre message a été envoyé avec succès. Notre équipe vous contactera sous peu.' }
        };
        const t = msgs[lang] || msgs.en;

        if (!company || !email || !message) {
            msgBox.className = 'status-msg error';
            msgBox.textContent = t.error;
            msgBox.style.display = 'block';
            return false;
        }
        if (!email.includes('@') || !email.includes('.')) {
            msgBox.className = 'status-msg error';
            msgBox.textContent = t.invalid;
            msgBox.style.display = 'block';
            return false;
        }

        msgBox.className = 'status-msg success';
        msgBox.textContent = t.success;
        msgBox.style.display = 'block';
        hideDirectEmail();

        setTimeout(() => {
            msgBox.className = 'status-msg';
            msgBox.textContent = '';
            msgBox.style.display = 'none';
        }, 6000);
        return false;
    }

    document.querySelectorAll('.office-card .contact-link').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            document.getElementById('contact').scrollIntoView({ behavior: 'smooth' });
        });
    });

    // ===== CALCULATOR =====
    function calculateInvestment() {
        const amount = parseFloat(document.getElementById('investAmount').value) || 0;
        const currency = document.getElementById('currency').value;
        const profitRate = parseFloat(document.querySelector('input[name="profitRate"]:checked').value);
        const period = parseInt(document.querySelector('input[name="period"]:checked').value);
        if (amount <= 0) {
            document.getElementById('calcResult').innerHTML = 'Please enter a valid amount.';
            return;
        }
        const profit = amount * (profitRate / 100);
        const total = amount + profit;
        const lang = document.documentElement.lang || 'en';
        const symbol = currency === 'USD' ? '$' : (currency === 'EUR' ? '€' : '£');
        const resultText = {
            en: `Investment: ${symbol}${amount.toLocaleString()} | Profit (${profitRate}%): ${symbol}${profit.toLocaleString()} | Total Return: ${symbol}${total.toLocaleString()} | Period: ${period} months`,
            ar: `الاستثمار: ${symbol}${amount.toLocaleString()} | الربح (${profitRate}%): ${symbol}${profit.toLocaleString()} | العائد الإجمالي: ${symbol}${total.toLocaleString()} | الفترة: ${period} شهر`,
            fr: `Investissement : ${symbol}${amount.toLocaleString()} | Profit (${profitRate}%) : ${symbol}${profit.toLocaleString()} | Retour total : ${symbol}${total.toLocaleString()} | Période : ${period} mois`
        };
        document.getElementById('calcResult').innerHTML = resultText[lang] || resultText.en;
    }
</script>
