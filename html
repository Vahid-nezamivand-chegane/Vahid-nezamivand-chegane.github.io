            gap: 16px; margin-top: 20px;
        }
        .partner-item {
            background: rgba(255,255,255,0.92); backdrop-filter: blur(4px);
            padding: 16px 12px; border-radius: 14px; box-shadow: var(--shadow);
            text-align: center; transition: var(--transition); border-bottom: 3px solid var(--gold);
