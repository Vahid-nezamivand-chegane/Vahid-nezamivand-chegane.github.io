        .university-grid .uni-item img {
            width: 100%; height: 100px; object-fit: contain; border-radius: 8px;
            margin-bottom: 8px; background: white; padding: 4px;
        }
        .university-grid .uni-item h5 { font-family: 'Poppins', sans-serif; font-size: 0.85rem; color: var(--dark); }
        .university-grid .uni-item p { font-size: 0.75rem; color: #6a7a8a; }
        .real-image { width: 100%; border-radius: var(--radius); object-fit: cover; }
