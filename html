<!-- ===== اسکریپت‌ها ===== -->
<!-- ============================= -->
<script>
    // انتخاب تاگ نوع درخواست
    function selectTag(el) {
        document.querySelectorAll('.request-tags .tag').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        document.getElementById('requestType').value = el.dataset.value;
    }

    // نمایش ایمیل مستقیم (تماس فوری)
    function showDirectEmail() {
        const box = document.getElementById('directEmailBox');
        box.style.display = 'block';
        box.scrollIntoView({ behavior: 'smooth', block: 'center' });
        // مخفی کردن پیام وضعیت قبلی
        document.getElementById('statusMsg').className = 'status-msg';
        document.getElementById('statusMsg').textContent = '';
    }

    function hideDirectEmail() {
        document.getElementById('directEmailBox').style.display = 'none';
    }

    // کپی ایمیل
    function copyEmail() {
        const email = 'vahid.aquanexus@protonmail.com';
        navigator.clipboard.writeText(email).then(() => {
            const msg = document.getElementById('statusMsg');
            msg.className = 'status-msg success';
            msg.textContent = '✅ ایمیل با موفقیت کپی شد!';
            setTimeout(() => { msg.className = 'status-msg'; msg.textContent = ''; }, 3000);
        }).catch(() => {
            // fallback
            const input = document.createElement('input');
            input.value = email;
            document.body.appendChild(input);
            input.select();
            document.execCommand('copy');
            document.body.removeChild(input);
            const msg = document.getElementById('statusMsg');
            msg.className = 'status-msg success';
            msg.textContent = '✅ ایمیل با موفقیت کپی شد!';
            setTimeout(() => { msg.className = 'status-msg'; msg.textContent = ''; }, 3000);
        });
    }

    // ارسال فرم (شبیه‌سازی)
    function handleSubmit(e) {
        e.preventDefault();
        const email = document.getElementById('email').value.trim();
        const company = document.getElementById('company').value.trim();
        const message = document.getElementById('message').value.trim();
        const msgBox = document.getElementById('statusMsg');

        // اعتبارسنجی ساده
        if (!company || !email || !message) {
            msgBox.className = 'status-msg error';
            msgBox.textContent = '❌ لطفاً تمام فیلدهای ضروری (نام شرکت، ایمیل، متن تماس) را پر کنید.';
            return false;
        }

        if (!email.includes('@') || !email.includes('.')) {
            msgBox.className = 'status-msg error';
            msgBox.textContent = '❌ لطفاً یک ایمیل معتبر با دامنه وارد کنید.';
            return false;
        }

        // شبیه‌سازی ارسال موفق
        msgBox.className = 'status-msg success';
        msgBox.textContent = '✅ پیام شما با موفقیت ارسال شد. تیم ما در اسرع وقت با شما تماس خواهد گرفت.';
        
        // پاک کردن فرم (اختیاری)
        // document.getElementById('mainForm').reset();
        // document.querySelectorAll('.request-tags .tag').forEach(t => t.classList.remove('active'));
        // document.querySelector('.request-tags .tag:first-child')?.classList.add('active');

        // مخفی کردن ایمیل مستقیم
        hideDirectEmail();

        setTimeout(() => {
            msgBox.className = 'status-msg';
            msgBox.textContent = '';
        }, 6000);

        return false;
    }

    // هدایت لینک‌های دفاتر به فرم تماس (همه به #contact)
    document.querySelectorAll('.office-card .contact-link').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            document.getElementById('contact').scrollIntoView({ behavior: 'smooth' });
        });
    });

    // بستن خودکار ایمیل مستقیم با کلیک خارج از آن (اختیاری)
    document.addEventListener('click', function(e) {
        const box = document.getElementById('directEmailBox');
        if (box.style.display === 'block') {
            const isClickInside = box.contains(e.target) || e.target.closest('.btn-secondary-form');
            if (!isClickInside) {
                // hideDirectEmail(); // غیرفعال برای جلوگیری از بسته شدن ناخواسته
            }
        }
    });

    console.log('🌍 AquaNexus — انقلاب صنعتی ۱۰۰۰ گیگاوات');
    console.log('🔒 اطلاعات فنی فقط پس از NDA در اختیار سرمایه‌گذاران معتبر قرار می‌گیرد.');
</script>

