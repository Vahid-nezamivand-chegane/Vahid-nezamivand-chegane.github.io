    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #0a2a44;
            --secondary: #1a6fb5;
            --accent: #2a9d8f;
            --gold: #e9c46a;
            --light-bg: #d4f1f9;
