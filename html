            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            object-fit: cover; z-index: 0;
        }
        .hero .hero-content {
            position: relative; z-index: 2; max-width: 950px; padding: 20px 30px;
            text-align: center; color: white; text-shadow: 0 4px 30px rgba(0,0,0,0.7);
        }
        .hero .hero-content h1 {
            font-family: 'Poppins', sans-serif; font-size: clamp(3rem, 8vw, 5.5rem);
