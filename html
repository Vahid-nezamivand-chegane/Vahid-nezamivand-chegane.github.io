            background: rgba(255,255,255,0.7); padding: 10px 20px; border-radius: 40px;
            border: 2px solid #dde4ec; cursor: pointer; transition: var(--transition);
            font-weight: 600; font-family: 'Inter', sans-serif; font-size: 0.95rem;
