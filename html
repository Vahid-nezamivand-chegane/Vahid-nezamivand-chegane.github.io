    <meta name="description" content="Geothermal+ Marine Technology Platform · Water·Energy·Food·Mineral·Precious Metals Security"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..700&family=Poppins:wght@300;600;700;800;900&display=swap" rel="stylesheet">
